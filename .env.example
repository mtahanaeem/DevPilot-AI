# ─── GitHub ─────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PAT=

# ─── LLM Provider (default: Groq) ───────────────────────────────────
LLM_PROVIDER=groq
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ─── Embeddings ─────────────────────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ─── Database ───────────────────────────────────────────────────────
POSTGRES_USER=devpilot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=devpilot

# ─── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Qdrant ─────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ─── Notifications ──────────────────────────────────────────────────
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=

# ─── App ────────────────────────────────────────────────────────────
JWT_SECRET=
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
